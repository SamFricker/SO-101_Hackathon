import serial
import json

PORT = "COM5"

ser = serial.Serial(PORT, 115200, timeout=2)
print(f"Connected to {PORT}. Reading AHT20...\n")

while True:
    line = ser.readline().decode(errors='ignore').strip()
    if not line:
        continue

    try:
        msg = json.loads(line)
        payload = msg.get("payload", {})
        if payload.get("event_type") == "sensor":
            key = payload["key"]
            value = payload["value"]
            if key == "humidity":
                print(f"Humidity:    {value:.1f} %")
            elif key == "temperature":
                print(f"Temperature: {value:.1f} °C")
    except (json.JSONDecodeError, KeyError):
        pass  # ignore boot messages and malformed lines
